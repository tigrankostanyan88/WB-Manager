<!doctype html>
<html lang="en">
    <head><%- include('../parts/head.ejs') %></head>
    <body>
        <%- include('../parts/navbar.ejs') %>
        <%- include('../parts/sidebar.ejs') %>
        <%- include('../parts/alert') %>
        <%- include('../parts/confirm') %>
        <!-- Main Content -->
        <main class="main-content">
            <section id="users">
                <div class="page-header">
                    <div>
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a href="index.html">Վահանակ</a></li>
                                <li class="breadcrumb-item active">Օգտվողներ</li>
                            </ol>
                        </nav>
                        <h1 class="page-title">Օգտվողների & ուսանողների կառավարում</h1>
                    </div>
                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addUserModal">
                        <i class="bi bi-plus-circle me-2"></i>Ավելացնել նոր ուսանող
                    </button>
                </div>

                <!-- Summary Cards -->
                <div class="row g-4 mb-4">
                    <div class="col-md-4">
                        <div class="stat-card">
                            <div class="icon primary">
                                <i class="bi bi-people"></i>
                            </div>
                            <div class="label">Ընդհանուր օգտվողներ</div>
                            <div class="number"><%- (typeof pagination !== 'undefined' && pagination.totalItems) ? pagination.totalItems : (users.length || 0) %></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="stat-card">
                            <div class="icon success">
                                <i class="bi bi-person-check"></i>
                            </div>
                            <div class="label">Ուսանողներ</div>
                            <div class="number"><%= studentCount.toLocaleString() %></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="stat-card">
                            <div class="icon warning">
                                <i class="bi bi-shield-check"></i>
                            </div>
                            <div class="label">Թիմի անդամներ</div>
                            <div class="number"><%= teamCount.toLocaleString() %></div>
                        </div>
                    </div>
                </div>

                <!-- Search and Filter Bar -->
                <div class="filter-row mb-4">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label">Փնտրել</label>
                            <input type="text" class="form-control" id="searchInput" placeholder="Փնտրել ուսանող…">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Կարգավիճակ</label>
                            <select class="form-select" id="filterStatus">
                                <option value="">Բոլորը</option>
                                <option value="user">Օգտվող</option>
                                <option value="student">Ուսանող</option>
                                <option value="team-member">Թիմի անդամ</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Users Table -->
                <div class="card">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Նկարը</th>
                                        <th>Անուն Ազգանուն</th>
                                        <th>Ռոլ</th>
                                        <th>Հեռախոս</th>
                                        <th>Էլ. փոստ</th>
                                        <th>Վճարված</th>
                                        <th>Գրանցման ամսաթիվ</th>
                                        <th>Կարգավիճակ</th>
                                        <th>Գործողություններ</th>
                                    </tr>
                                </thead>
                                <tbody id="usersTableBody">
                                    <%- include('../partials/users_table_body.ejs') %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div id="paginationContainer">
                        <%- include('../partials/pagination.ejs') %>
                    </div>
                </div>
            </section>
        </main>

        <!-- Add User Modal -->
        <div class="modal fade" id="addUserModal" tabindex="-1">
            <div class="modal-dialog">
                <form method="post" action="/api/v1/user/signUpByAdmin" enctype="multipart/form-data" id="addUserForm">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Ավելացնել նոր ուսանող</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Անուն</label>
                                        <input type="text" name="name" class="form-control validate" placeholder="Անունը">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Ազգանուն</label>
                                        <input type="text" name="last_name" class="form-control validate" placeholder="ազգանունը">
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Հեռախոս</label>
                                    <input type="tel" name="phone" class="form-control validate" placeholder="091234567">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Էլ. փոստ</label>
                                    <input type="email" name="email" class="form-control validate" placeholder="example@email.com">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Գաղտնաբառ</label>
                                    <input type="password" name="password" class="form-control validate" placeholder="Գաղտնաբառ">
                                </div>
                                <div class="row mb-3">
                                    <div class="col-md-12">
                                        <label class="form-label">Կարգավիճակ</label>
                                        <select name="role" class="form-select validate">
                                            <option value="user">Օգտվող</option>
                                            <option value="student">Ուսանող</option>
                                            <option value="team-member">Թիմի անդամ</option>
                                        </select>
                                    </div>
                                </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Չեղարկել</button>
                            <button type="submit" class="btn btn-primary" form="addUserForm">Գրանցել ուսանողին</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- Edit User Role Modal -->
        <div class="modal fade" id="editUserRoleModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Խմբագրել օգտվողի կարգավիճակ</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <form id="editUserRoleForm">
                            <input type="hidden" id="editUserId">
                            <div class="mb-3">
                                <label class="form-label">Անուն Ազգանուն</label>
                                <input type="text" class="form-control" id="editUserName">
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Էլ. փոստ</label>
                                <input type="email" class="form-control" id="editUserEmail">
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Ռոլ (Կարգավիճակ)</label>
                                <select class="form-select" id="editUserRole" required>
                                    <option value="user">Օգտվող</option>
                                    <option value="student">Ուսանող</option>
                                    <option value="teacher">Ուսուցիչ</option>
                                    <option value="admin">Ադմին</option>
                                </select>
                            </div>
                            <div class="mb-3 form-check">
                                <input type="checkbox" class="form-check-input" id="editUserIsPaid">
                                <label class="form-check-label" for="editUserIsPaid">Վճարված է (PRO)</label>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Դասընթացների մուտք</label>
                                <div id="coursesList" class="border rounded p-3" style="max-height: 200px; overflow-y: auto;">
                                    <div class="text-muted">Բեռնում...</div>
                                </div>
                            </div>
                        </form>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Չեղարկել</button>
                        <button type="button" class="btn btn-primary" id="saveUserRoleBtn">Պահպանել</button>
                    </div>
                </div>
            </div>
        </div>
        <%- include('../parts/scripts.ejs') %>
        <script>
            // Store all courses and current user's course_ids
            let allCourses = [];
            let currentUserId = null;

            // Fetch all courses on page load
            async function fetchCourses() {
                try {
                    const response = await axios.get('/api/v1/courses');
                    allCourses = response.data.data || [];
                } catch (error) {
                    console.error('Error fetching courses:', error);
                    allCourses = [];
                }
            }

            // Load courses into the modal with checkboxes
            function loadCoursesIntoModal(userCourseIds = []) {
                const container = document.getElementById('coursesList');
                if (allCourses.length === 0) {
                    container.innerHTML = '<div class="text-muted">Դասընթացներ չկան</div>';
                    return;
                }

                const courseIds = Array.isArray(userCourseIds) ? userCourseIds.map(String) : [];
                
                container.innerHTML = allCourses.map(course => {
                    const isChecked = courseIds.includes(String(course.id));
                    return `
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" value="${course.id}" id="course_${course.id}" ${isChecked ? 'checked' : ''}>
                            <label class="form-check-label" for="course_${course.id}">
                                ${course.title}
                            </label>
                        </div>
                    `;
                }).join('');
            }

            // Handle modal open - load user data and courses
            document.getElementById('editUserRoleModal').addEventListener('show.bs.modal', async function(event) {
                const button = event.relatedTarget;
                currentUserId = button.getAttribute('data-user-id');
                const userName = button.getAttribute('data-user-name');
                const userEmail = button.getAttribute('data-user-email');
                const userRole = button.getAttribute('data-user-role');
                const userIsPaid = button.getAttribute('data-user-is-paid') === 'true';

                // Set basic user info
                document.getElementById('editUserId').value = currentUserId;
                document.getElementById('editUserName').value = userName || '';
                document.getElementById('editUserEmail').value = userEmail || '';
                document.getElementById('editUserRole').value = userRole || 'user';
                document.getElementById('editUserIsPaid').checked = userIsPaid;

                // Show loading
                document.getElementById('coursesList').innerHTML = '<div class="text-muted">Բեռնում...</div>';

                // Fetch user's course_ids from user data (passed via data attribute or fetch)
                let userCourseIds = [];
                try {
                    const response = await axios.get(`/api/v1/users/${currentUserId}`);
                    if (response.data && response.data.user) {
                        userCourseIds = response.data.user.course_ids || [];
                    }
                } catch (error) {
                    console.log('Could not fetch user details, using empty course_ids');
                }

                // Load courses with user's selections
                loadCoursesIntoModal(userCourseIds);
            });

            // Handle save button click
            document.getElementById('saveUserRoleBtn').addEventListener('click', async function() {
                const userId = document.getElementById('editUserId').value;
                const role = document.getElementById('editUserRole').value;
                const isPaid = document.getElementById('editUserIsPaid').checked;

                // Get selected courses
                const selectedCourses = [];
                document.querySelectorAll('#coursesList input[type="checkbox"]:checked').forEach(checkbox => {
                    selectedCourses.push(parseInt(checkbox.value, 10));
                });

                try {
                    const response = await axios.patch(`/api/v1/users/${userId}`, {
                        role: role,
                        isPaid: isPaid,
                        course_ids: selectedCourses
                    });

                    if (response.data.status === 'success') {
                        // Close modal and reload page
                        const modal = bootstrap.Modal.getInstance(document.getElementById('editUserRoleModal'));
                        modal.hide();
                        window.location.reload();
                    } else {
                        alert('Սխալ է տեղի ունեցել։ Խնդրում ենք փորձել կրկին։');
                    }
                } catch (error) {
                    console.error('Error updating user:', error);
                    alert('Սխալ է տեղի ունեցել։ Խնդրում ենք փորձել կրկին։');
                }
            });

            // Fetch courses on page load
            fetchCourses();
        </script>
    </body>
</html>
