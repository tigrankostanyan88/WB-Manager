# Server Configuration
PORT=3300
NODE_ENV=development

# Database
DB_NAME=your_database_name
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=3306

# Security
SESSION_SECRET=your_random_session_secret_min_32_chars
JWT_EXPIRES_IN=60
JWT_SECRET=your_random_jwt_secret_min_32_chars_secure_random

# Cookie
COOKIE_KEY=your_random_cookie_key

# Client
CLIENT_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3300

# Google Sheets (optional)
SPREADSHEET_ID=your_google_sheet_id

# Email Configuration
EMAIL_FROM_NAME=Your App Name
EMAIL_FROM_EMAIL=your_email@example.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USERNAME=your_email@example.com
EMAIL_PASSWORD=your_app_password

# SendPulse / Mailtrap (optional for testing)
SENDPULSE_HOST=sandbox.smtp.mailtrap.io
SENDPULSE_PORT=2525
SENDPULSE_USERNAME=your_mailtrap_username
SENDPULSE_PASSWORD=your_mailtrap_password

# Cloudflare / Redis (optional)
UPSTASH_REDIS_REST_URL=your_redis_url
UPSTASH_REDIS_REST_TOKEN=your_redis_token

# Stripe (optional)
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_key

# OpenAI (optional)
OPENAI_API_KEY=sk-your_openai_key
