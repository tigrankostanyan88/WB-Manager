# ───────────────────────────────────────────────────────────────
# 2. PROJECT STRUCTURE — Canonical Map (Actual)
# ───────────────────────────────────────────────────────────────

# ── Backend (Node.js / Express) ─────────────────────────────
src/
  constants/           # App-wide enums, string constants, config values
  controllers/         # HTTP handler functions — THIN, logic-free
  models/              # DB models (Mongoose/Sequelize schemas)
  repositories/        # DB query layer — ALL database calls go here
  routes/              # Express route definitions + middleware chain
  services/            # Business logic — orchestrates repo + external calls
  utils/               # Pure helper functions (format, crypto, date…)
  views/               # EJS templates (server-rendered partials)
  workers/             # Background jobs / queue processors

app.js                 # Express app setup + middleware registration
config/                # DB connection, env validation, app config
k6-testing/            # Load test scripts — NEVER touch during features
public/                # Static assets — NEVER touch unless asked
views/                 # Top-level EJS (admin/, email/, notFound/, error.ejs)
.env                   # ❌ NEVER read, print, log, or expose

# ── Frontend (Next.js Dashboard) ────────────────────────────
client/
  app/
    (auth)/            # Login, register pages
    dashboard/
      layout.tsx       # Dashboard shell / sidebar
      page.tsx         # Dashboard home
      [feature]/
        page.tsx
        _components/   # Page-local components (underscore = private)
    api/               # Next.js Route Handlers (BFF layer)
  components/
    ui/                # Primitive UI (Button, Input, Modal…)
    shared/            # Cross-page reusable
    dashboard/         # Dashboard-specific compound components
  hooks/               # Custom React hooks (use*.ts)
  lib/
    api.ts             # Centralized fetch wrapper (typed)
    utils.ts
    constants.ts
  styles/              # Global CSS, Tailwind config
  types/               # TypeScript interfaces / DTOs


# ───────────────────────────────────────────────────────────────
# 3. BACKEND LAYER RULES — Request Flow
# ───────────────────────────────────────────────────────────────

# STRICT layer order — կատարյալ request path-ը.
#
#   Route → Middleware → Controller → Service → Repository → Model
#
# ❌ Controller-ը ՉՊԵՏՔ Է ուղղակի Model կամ Repository հասնի
# ❌ Repository-ն ՉՊԵՏՔ Է business logic ունենա
# ❌ Service-ը ՉՊԵՏՔ Է req/res object-ների մասին գիտենա

## Controller (THIN — only HTTP concerns)
const getUsers = async (req, res, next) => {
  try {
    const result = await userService.findAll(req.query)   // service only
    res.json({ success: true, data: result })
  } catch (err) {
    next(err)    // ALWAYS next(err), never res.json(err) directly
  }
}

## Service (Business Logic)
const findAll = async (filters) => {
  const users = await userRepository.findAll(filters)     // repo only
  return users.map(formatUserResponse)                    // transform here
}

## Repository (DB Access Only)
const findAll = async (filters) => {
  return User.find(filters).lean()                        // model only
}

## Workers (src/workers/)
  - Queue consumer-ներ — process jobs, don't handle HTTP
  - Worker կարող է service layer կանչել, բայց ոչ DB ուղղակի
  - Errors → log, don't throw (background job-ը չի կարող crash անել server-ը)
  - Always idempotent (retry-safe)

## API Response Format (STRICT)
  Success: { success: true,  data: T,       meta?: { page, limit, total } }
  Error:   { success: false, error: string, code?: string                 }

## Route Naming (RESTful)
  GET    /api/v1/users          # List
  POST   /api/v1/users          # Create
  GET    /api/v1/users/:id      # Read one
  PATCH  /api/v1/users/:id      # Partial update
  DELETE /api/v1/users/:id      # Delete

## Security Rules (NEVER skip)
  ✅ Validation — EVERY endpoint-ում (joi / express-validator / zod)
  ✅ Auth middleware — route level-ում, ոչ controller-ում
  ✅ Rate limiting — auth, password reset endpoints-ի վրա
  ❌ NEVER log req.body password կամ token field-ներ
  ❌ NEVER return raw DB error to client
  ❌ NEVER eval() կամ raw SQL string concat

## Views (EJS — views/)
  - views/admin/   → admin panel templates
  - views/email/   → email templates (HTML)
  - views/notFound/ + error.ejs → error pages
  - EJS-ի մեջ logic MINIMUM — logic-ը controller/service-ում


# ───────────────────────────────────────────────────────────────
# 4. FRONTEND STANDARDS — Next.js / React
# ───────────────────────────────────────────────────────────────

## Component Rules
  - Server Component = default (async, direct data fetch, no hooks)
  - Client Component = "use client" — ONLY useState/useEffect/events-ի համար
  - Data fetching → Server Components կամ SWR/React Query
  - Forms → react-hook-form + Server Action կամ API route

## TypeScript Rules
  - Ոչ մի "any" առանց // TODO comment-ի
  - Props interface-ը ALWAYS explicit
  - Shared types → client/types/ folder-ում

## Forbidden Patterns
  ❌ useEffect-ի մեջ fetch() — Server Component կամ SWR use
  ❌ "any" type
  ❌ inline styles — Tailwind կամ CSS modules
  ❌ key={index} list-ներում (stable unique id use)
  ❌ console.log production code-ում


